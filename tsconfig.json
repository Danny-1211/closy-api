{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    /* 執行環境設定 */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* 輸出設定 */
    "sourceMap": true,
    "declaration": false,

    /* 嚴格檢查模式 */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
